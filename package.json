{
  "name": "grif",
  "version": "2.0.0",
  "productName": "GRIF",
  "private": true,
  "type": "module",
  "scripts": {
    "backend": "python3 web_backend.py --port 8765",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "dist:release": "npm run build && electron-builder --mac dmg zip --linux AppImage deb",
    "preview": "vite preview --host 127.0.0.1",
    "test:unit": "PYTHONPATH=. python3 tests/test_basic.py",
    "test:e2e": "playwright test",
    "check": "npm run build && npm run test:unit && npm run test:e2e",
    "electron": "electron electron/main.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "ru.grif.disk-analyzer",
    "productName": "GRIF",
    "asar": false,
    "directories": {
      "output": "release-builds"
    },
    "files": [
      "dist/web/**/*",
      "electron/**/*",
      "web_backend.py",
      "commands.py",
      "__init__.py",
      "core/**/*",
      "fs/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "GRIF-macOS-${version}-${arch}.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "GRIF-Linux-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "GRIF-macOS-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "GRIF-Linux-${version}-${arch}.${ext}",
      "maintainer": "user-not-a-human <user-not-a-human@users.noreply.github.com>"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron-builder": "^26.15.0",
    "electron": "^42.3.0"
  },
  "description": "программа для анализа образов дисков",
  "author": {
    "name": "user-not-a-human",
    "email": "user-not-a-human@users.noreply.github.com"
  },
  "main": "electron/main.cjs"
}
